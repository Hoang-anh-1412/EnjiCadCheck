<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <PlatformTarget>x64</PlatformTarget>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <!-- Set ENJICAD_DIR to your enjiCAD install folder, or put DLLs in .\refs -->
    <EnjiCadDir Condition="'$(EnjiCadDir)' == ''">$(ENJICAD_DIR)</EnjiCadDir>
    <EnjiCadDir Condition="'$(EnjiCadDir)' == ''">$(MSBuildThisFileDirectory)refs</EnjiCadDir>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="GcCoreMgd">
      <HintPath>$(EnjiCadDir)\GcCoreMgd.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="GcDbMgd">
      <HintPath>$(EnjiCadDir)\GcDbMgd.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="GcMgd">
      <HintPath>$(EnjiCadDir)\GcMgd.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
</Project>
